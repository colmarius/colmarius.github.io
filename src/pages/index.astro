---
import AboutMeSummary from '@components/index/AboutMeSummary.astro';
import HelloMessage from '@components/index/HelloMessage.astro';
import ReachOutMessage from '@components/index/ReachOutMessage.astro';
import Layout from '@layouts/Layout.astro';
---

<Layout title="Marius Colacioiu – Engineering Leader and Entrepreneur">
  <div class="space-y-32 sm:space-y-40">
    <HelloMessage />
    <AboutMeSummary />
    <section class="max-w-3xl mx-auto">
      <p class="text-sm text-gray-800">
        <span class="text-gray-600">Featured:</span>
        <a href="https://with-agents.dev" target="_blank" rel="noopener noreferrer" class="text-indigo-700 hover:text-indigo-500 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-600/50 focus-visible:ring-offset-2 rounded-sm">
          My coding-agent guides moved to With Agents →
        </a>
      </p>
    </section>
    <ReachOutMessage />
  </div>
</Layout>
